# Supabase (database + storage)
DATABASE_URL=postgresql://postgres:password@db.xxx.supabase.co:5432/postgres
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# NextAuth
NEXTAUTH_SECRET=generate-a-long-random-string
NEXTAUTH_URL=http://localhost:3000

# Public domain (subdomains: [slug].yourdomain → /p/[slug])
NEXT_PUBLIC_APP_DOMAIN=localhost:3000

# Default country (ISO 3166-1 alpha-2) for phone numbers submitted without a country code
DEFAULT_COUNTRY_CODE=ZW

# Resend — both required for outbound email (From must use a domain verified in Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=notifications@yourdomain.com

# ---------------------------------------------------------------------------
# Meta WhatsApp Cloud API
# Prereqs (do before production sends): Business Verification, WABA, phone
# number on the WABA, "Leadstaq" display name approved, System User token with
# whatsapp_business_messaging + whatsapp_business_management, 5 message templates
# approved in Business Manager, webhook "messages" field subscribed (see
# docs/meta-whatsapp-setup.md). Same Meta app as Facebook Lead Ads; reuse
# FACEBOOK_APP_SECRET for webhook signature verification.
META_WHATSAPP_PHONE_NUMBER_ID=
META_WHATSAPP_BUSINESS_ACCOUNT_ID=
META_WHATSAPP_ACCESS_TOKEN=
# Verify token for WhatsApp webhook (GET challenge). Can match FACEBOOK_WEBHOOK_VERIFY_TOKEN or be distinct.
META_WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# Language code for WhatsApp templates — must match the approved template language in Business Manager
META_TEMPLATE_LANGUAGE=en_US

# ---------------------------------------------------------------------------
# Facebook Lead Ads — OAuth + webhook (add redirect URL in Meta app: Valid OAuth Redirect URIs)
# OAuth scopes in code include ads_read and pages_manage_ads (Campaigns / Marketing API + Page-linked ads).
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=http://localhost:3000/api/facebook/oauth/callback
FACEBOOK_WEBHOOK_VERIFY_TOKEN=your-verify-token
# Meta Cloud API and Lead Ads use the same Graph version.
FACEBOOK_API_VERSION=v19.0

# ---------------------------------------------------------------------------
# Cloudflare R2 — object storage for project photos and hero images
# Create a bucket at dash.cloudflare.com → R2 → Create bucket
# Create API token with Object Read & Write permissions
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET_NAME=leadstaq-media
CLOUDFLARE_R2_PUBLIC_URL=  # e.g. https://media.leadstaq.tech (custom domain on R2 bucket)

# Long random string for authenticating cron requests from GitHub Actions.
# Generate with: openssl rand -hex 32
CRON_SECRET=

# ---------------------------------------------------------------------------
# Anthropic Claude — AI features (lead briefing, form generation, win insights)
ANTHROPIC_API_KEY=your_anthropic_api_key

# ---------------------------------------------------------------------------
# Twilio (deprecated — kept for rollback; outbound WhatsApp uses Meta Cloud API above)
# Do not remove from production until Meta migration is verified; see `lib/messaging/provider.ts` rollback.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_CONTENT_SID_NEW_LEAD_SALESPERSON=
TWILIO_CONTENT_SID_NEW_LEAD_MANAGER=
TWILIO_CONTENT_SID_DEAL_WON=
TWILIO_CONTENT_SID_FOLLOW_UP_REMINDER=
TWILIO_CONTENT_SID_UNCONTACTED_LEAD_ALERT=
